local function CreateESP(object, text, color, stateKey, isLock)
    if ESP_Storage[object] and not isLock then return end
    if ESP_Storage[object] and isLock then
        pcall(function() ESP_Storage[object][2].TextLabel.Text = text end)
        return
    end
    
    local Box = Instance.new("Highlight")
    Box.Adornee = object
    Box.FillColor = color
    Box.FillTransparency = 0.6
    Box.OutlineColor = Color3.fromRGB(255, 255, 255)
    Box.OutlineTransparency = 0.2
    Box.Parent = ScreenGui
    
    local Billboard = Instance.new("BillboardGui")
