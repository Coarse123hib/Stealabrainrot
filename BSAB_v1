-- Поиск ближайшего игрока для AUTOWEB
local function GetClosestPlayer()
    local Target = nil
    local MinDistance = math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local Root = player.Character.HumanoidRootPart
            local Distance = (Root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if Distance < MinDistance then
                MinDistance = Distance
                Target = Root
            end
        end
    end
    return Target
end

-- Контур AUTOWEB (Экипировка + жесткое наведение)
RunService.RenderStepped:Connect(function()
    if States.AutoWeb and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local Backpack = LocalPlayer:FindFirstChild("Backpack")
        local Weapon = LocalPlayer.Character:FindFirstChild("Web Slinger") or LocalPlayer.Character:FindFirstChild("WebSlinger")
        
        -- Авто-взятие в руки
        if not Weapon and Backpack then
            local TargetWeapon = Backpack:FindFirstChild("Web Slinger") or Backpack:FindFirstChild("WebSlinger")
            if TargetWeapon then
                TargetWeapon.Parent = LocalPlayer.Character
            end
