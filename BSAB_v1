    Button.Text = "[OFF]"
    Button.TextColor3 = Color3.fromRGB(150, 150, 150)
    Button.Font = Enum.Font.Arcade
    Button.TextSize = 10
    Button.Parent = Frame
    
    local enabled = false
    Button.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            Button.TextColor3 = Color3.fromRGB(255, 0, 127)
            Button.Text = "[ON]"
        else
            Button.TextColor3 = Color3.fromRGB(150, 150, 150)
            Button.Text = "[OFF]"
        end
        callback(enabled)
    end)
end

