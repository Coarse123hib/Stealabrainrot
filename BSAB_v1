-- Безопасный обход античита прыжков через импульс физики
local LastJump = 0
UserInputService.JumpRequest:Connect(function()
    if States.InfJump and tick() - LastJump > 0.15 then
        local Character = LocalPlayer.Character
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        
        if Root and Humanoid then
            LastJump = tick()
            Root.Velocity = Vector3.new(Root.Velocity.X, States.JumpBoost and States.JumpValue or 50, Root.Velocity.Z)
        end
    end
end)

-- Контур контроля SpeedBoost и стандартного JumpBoost
RunService.PostSimulation:Connect(function()
    local Character = LocalPlayer.Character
    if Character then
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then
            if States.SpeedBoost then
                Humanoid.WalkSpeed = States.SpeedValue
            end
            if States.JumpBoost and not States.InfJump then
                Humanoid.JumpPower = States.JumpValue
                Humanoid.UseJumpPower = true
            elseif not States.JumpBoost and not States.InfJump then
                Humanoid.JumpPower = 50
            end
        end
    end
end)

-- Поиск ближайшего игрока для AUTOWEB
local function GetClosestPlayer()
    local Target = nil
    local MinDistance = math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local Root = player.Character.HumanoidRootPart
            local Distance = (Root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if Distance < MinDistance then
                MinDistance = Distance
                Target = Root
            end
        end
    end
    return Target
end

-- Контур AUTOWEB (Экипировка + жесткое наведение)
RunService.RenderStepped:Connect(function()
    if States.AutoWeb and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local Backpack = LocalPlayer:FindFirstChild("Backpack")
        local Weapon = LocalPlayer.Character:FindFirstChild("Web Slinger") or LocalPlayer.Character:FindFirstChild("WebSlinger")
        
        -- Авто-взятие в руки
        if not Weapon and Backpack then
            local TargetWeapon = Backpack:FindFirstChild("Web Slinger") or Backpack:FindFirstChild("WebSlinger")
            if TargetWeapon then
                TargetWeapon.Parent = LocalPlayer.Character
            end
        end
        
        -- Наведение камеры на ближайшую цель
        local Target = GetClosestPlayer()
        if Target then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Position)
        end
    end
end)

-- Контур AUTOGRAB (Автоматический сбор Brainrot через ProximityPrompt)
task.spawn(function()
    while true do
        task.wait(0.1)
        if States.AutoGrab and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local Root = LocalPlayer.Character.HumanoidRootPart
            for _, desc in ipairs(Workspace:GetDescendants()) do
                if desc:IsA("ProximityPrompt") then
                    local ParentPart = desc.Parent
                    if ParentPart and ParentPart:IsA("BasePart") then
                        local Distance = (ParentPart.Position - Root.Position).Magnitude
                        if Distance <= (desc.MaxActivationDistance or 15) then
                            pcall(function()
                                fireproximityprompt(desc, 1)
                            end)
                        end
                    end
                end
            end
        end
    end
end)

-- Контур управления динамической платформой FLYFLOOR
local function ManageFlyFloor(enable)
    if FloorConnection then 
        FloorConnection:Disconnect() 
        FloorConnection = nil 
    end
    if ActiveFloor then 
        ActiveFloor:Destroy() 
        ActiveFloor = nil 
    end

    if enable then
        local Character = LocalPlayer.Character
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        if not Root then return end

        -- Создание компактной тонкой платформы малинового цвета
        ActiveFloor = Instance.new("Part")
        ActiveFloor.Size = Vector3.new(6, 0.5, 6)
        ActiveFloor.Material = Enum.Material.Neon
        ActiveFloor.Color = Color3.fromRGB(255, 0, 127)
        ActiveFloor.Anchored = true
        ActiveFloor.CanCollide = true
        ActiveFloor.Position = Root.Position - Vector3.new(0, 3.25, 0)
        ActiveFloor.Parent = Workspace

        local StartTime = tick()
        local TargetY = ActiveFloor.Position.Y
        local SpeedY = 8 -- Скорость подъема платформы (студий в секунду)

        FloorConnection = RunService.Heartbeat:Connect(function(dt)
            local CurrentCharacter = LocalPlayer.Character
            local CurrentRoot = CurrentCharacter and CurrentCharacter:FindFirstChild("HumanoidRootPart")
            
            if ActiveFloor and CurrentRoot then
                local TimePassed = tick() - StartTime
                if TimePassed < 5 then
                    -- Фаза 1: Подъем вверх в течение 5 секунд + следование по XZ
                    TargetY = TargetY + (SpeedY * dt)
                    ActiveFloor.Position = Vector3.new(CurrentRoot.Position.X, TargetY, CurrentRoot.Position.Z)
                else
                    -- Фаза 2: Остановка подъема, жесткое удержание высоты и следование по XZ
                    ActiveFloor.Position = Vector3.new(CurrentRoot.Position.X, TargetY, CurrentRoot.Position.Z)
                end
            else
                ManageFlyFloor(false)
            end
        end)
    end
end

