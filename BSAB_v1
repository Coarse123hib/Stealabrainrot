    Label.TextColor3 = color
    Label.Font = Enum.Font.Arcade
    Label.TextSize = 12
    Label.Parent = Billboard
    Billboard.Parent = ScreenGui
    
    ESP_Storage[object] = {Box, Billboard}
    
    task.spawn(function()
        while object and object.Parent and States[stateKey] do task.wait(0.5) end
        Box:Destroy()
        Billboard:Destroy()
        ESP_Storage[object] = nil
    end)
end

