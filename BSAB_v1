-- Контур управления динамической платформой FLYFLOOR
local function ManageFlyFloor(enable)
    if FloorConnection then 
        FloorConnection:Disconnect() 
        FloorConnection = nil 
    end
    if ActiveFloor then 
        ActiveFloor:Destroy() 
        ActiveFloor = nil 
    end

    if enable then
        local Character = LocalPlayer.Character
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        if not Root then return end

        -- Создание компактной тонкой платформы малинового цвета
        ActiveFloor = Instance.new("Part")
        ActiveFloor.Size = Vector3.new(6, 0.5, 6)
        ActiveFloor.Material = Enum.Material.Neon
        ActiveFloor.Color = Color3.fromRGB(255, 0, 127)
        ActiveFloor.Anchored = true
        ActiveFloor.CanCollide = true
        ActiveFloor.Position = Root.Position - Vector3.new(0, 3.25, 0)
        ActiveFloor.Parent = Workspace

        local StartTime = tick()
        local TargetY = ActiveFloor.Position.Y
        local SpeedY = 8 -- Скорость подъема платформы (студий в секунду)

        FloorConnection = RunService.Heartbeat:Connect(function(dt)
            local CurrentCharacter = LocalPlayer.Character
            local CurrentRoot = CurrentCharacter and CurrentCharacter:FindFirstChild("HumanoidRootPart")
            
            if ActiveFloor and CurrentRoot then
                local TimePassed = tick() - StartTime
                if TimePassed < 5 then
                    -- Фаза 1: Подъем вверх в течение 5 секунд + следование по XZ
                    TargetY = TargetY + (SpeedY * dt)
                    ActiveFloor.Position = Vector3.new(CurrentRoot.Position.X, TargetY, CurrentRoot.Position.Z)
                else
                    -- Фаза 2: Остановка подъема, жесткое удержание высоты и следование по XZ
                    ActiveFloor.Position = Vector3.new(CurrentRoot.Position.X, TargetY, CurrentRoot.Position.Z)
                end
            else
                ManageFlyFloor(false)
            end
        end)
    end
end

